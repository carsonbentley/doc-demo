# GrantComply Environment Variables
# Copy this file to create .env.local files in each directory

# ===========================================
# apps/frontend/.env.local
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_AGENT_API_URL=http://localhost:8002
NEXT_PUBLIC_AI_API_URL=http://localhost:8002
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GOOGLE_API_KEY=your_google_api_key

# ===========================================
# apps/backend/.env
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
API_PORT=8002
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000



# ===========================================
# How to get these values:
# ===========================================
# 1. Create a Supabase project at https://supabase.com
# 2. Go to Settings > API to find your URL and keys
# 3. Get an OpenAI API key at https://platform.openai.com/api-keys
# 4. Create Google OAuth credentials at https://console.cloud.google.com/apis/credentials
#    - Create OAuth 2.0 Client ID for web application
#    - Add authorized redirect URIs: http://localhost:3000
#    - Enable Google Drive API and Google Docs API
