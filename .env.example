# ComplyFlow Environment Variables
# Copy this file to create .env.local files in each directory

# ===========================================
# apps/frontend/.env.local
# ===========================================
# Use only the anon (or publishable) Supabase key here — never SUPABASE_SERVICE_ROLE_KEY
# in the frontend app; that key bypasses RLS and belongs only on the backend.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_AGENT_API_URL=http://localhost:8002

# ===========================================
# apps/backend/.env
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
API_PORT=8002



# ===========================================
# How to get these values:
# ===========================================
# 1. Create a Supabase project at https://supabase.com
# 2. Go to Settings > API to find your URL and keys
# 3. Get an OpenAI API key at https://platform.openai.com/api-keys
