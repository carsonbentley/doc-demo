# Vercel ignore file for frontend deployment

# Development files
.env
.env.local
.env.*.local

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Dependencies (will be installed)
node_modules/

# Build outputs (will be generated)
.next/
out/
dist/

# Testing
coverage/
.nyc_output/

# Logs
*.log
logs/

# Other services (not needed for frontend)
../backend/
../../addon/
../../docs/
../../supabase/
../../tools/
